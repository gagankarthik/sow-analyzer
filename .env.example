# =============================================================================
# Blue-IQ — environment variables
#
# Local dev:  copy this file to `.env.local` and fill in real values.
# Production: set each of these in Vercel → Project → Settings →
#             Environment Variables (Production + Preview).
#
# NEXT_PUBLIC_* values are inlined into the client bundle at BUILD time, so they
# MUST exist when Vercel builds — a missing one ships as `undefined`.
# Everything without the prefix is server-only and must NEVER be exposed.
# =============================================================================

# --- Public client config (safe to expose; inlined at build time) ------------

# Backend API Gateway base URL — no trailing slash.
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.us-east-2.amazonaws.com

# Default tenant id, sent as the `x-tenant-id` fallback header.
NEXT_PUBLIC_TENANT_ID=default

# Canonical site origin — used for metadata / OpenGraph absolute URLs.
# In Vercel set this to your production domain (e.g. https://blue-iq.vercel.app).
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# AWS Cognito user pool — public client (SRP, no client secret).
# The amazon-cognito-identity-js SDK reads these in the browser.
NEXT_PUBLIC_COGNITO_REGION=us-east-2
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-2_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC_) --------------------

# OpenAI key used by the SOW drafter (app/api/sow/*). Required for AI drafting.
OPENAI_API_KEY=sk-...

# Optional — override the OpenAI model. Default: gpt-4.1-mini.
# OPENAI_MODEL=gpt-4.1-mini

# Optional — custom OpenAI-compatible base URL. Default: https://api.openai.com/v1.
# OPENAI_BASE_URL=https://api.openai.com/v1
